<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>

  <title>Report Esame <%= exam.id %></title>

  <style>
    body { font-family: Arial, sans-serif; font-size: 12px; }

    .header { text-align: center; margin-bottom: 20px; }
    .logo { display: block; margin: 0 auto; width: 140px; margin-bottom: 20px; }

    .qr { width: 110px; position: absolute; top: 40px; right: 40px; }

    .box { border: 1px solid #000; padding: 10px; margin-bottom: 15px; }
    .row { margin-bottom: 6px; }
    .label { font-weight: bold; }

    .question {
      margin-top: 20px;
      padding: 10px;
      border: 1px solid #999;
      border-radius: 6px;
      background: #f9f9f9;
    }

    .option {
      margin-left: 10px;
      padding: 2px 0;
      font-size: 12px;
    }

    .signature {
      margin-top: 70px;
      display: flex;
      justify-content: space-between;
      padding: 0 40px;
    }
    .signature div {
      text-align: center;
      width: 40%;
    }
  </style>
</head>

<body>

<h1 style="color:red;">FILE IN USO</h1>

<img src="data:image/png;base64,<%= logoBase64 %>" class="logo">
<img src="data:image/png;base64,<%= qrBase64 %>" class="qr">

<div class="header">
  <h2 style="margin: 0;">CENTRO ADDESTRAMENTO E STANDARDIZZAZIONE EQUIPAGGI DI VOLO</h2>
  <h3 style="margin: 0;">NUCLEO ADDESTRAMENTO ALA FISSA</h3>
  <h3 style="margin: 0;">PESCARA</h3>
</div>

<div class="box">

  <div class="row"><span class="label">Nominativo:</span> <%= exam.rank %> <%= exam.surname %> <%= exam.name %></div>
  <div class="row"><span class="label">Reparto di appartenenza:</span> <%= exam.reparto %></div>

  <div class="row">
    <span class="label">Data:</span>
    <% 
      const mesi = ["gen","feb","mar","apr","mag","giu","lug","ago","set","ott","nov","dic"];
      const d = new Date(exam.started_at);
      const dataIt = d.getDate() + " " + mesi[d.getMonth()] + " " + d.getFullYear();
    %>
    <%= dataIt %>
  </div>

  <div class="row"><span class="label">Istruttore:</span> <%= exam.instructor_name %></div>
  <div class="row"><span class="label">Email istruttore:</span> <%= exam.instructor_email %></div>

  <div class="row"><span class="label">Tipologia test:</span> <%= exam.exam_type %></div>

  <div class="row">
    <span class="label">Esito:</span>
    <% if (exam.score_percent >= 70) { %>
      <span style="color:#008000; font-weight:bold;">TEST PASSATO</span>
    <% } else { %>
      <span style="color:#cc0000; font-weight:bold;">TEST RESPINTO</span>
    <% } %>
  </div>

  <div class="row"><span class="label">Risultato:</span> <%= exam.score_percent %> %</div>
</div>

<!-- DOMANDE -->
<% items.forEach((q, idx) => { %>
  <div class="question">

    <div class="label">Domanda n° <%= idx+1 %> — ID <%= q.question_id %> — Argomento <%= q.topic %></div>
    <div style="margin-bottom: 8px;"><%= q.question %></div>

    <!-- OPZIONI COLORATE -->
    <div style="margin-bottom: 10px;">

      <!-- A -->
      <div class="option">
        <% const chosenA = q.chosen_key === "A"; const correctA = q.correct_key === "A"; %>
        <span style="
          color:<%= chosenA && !correctA ? '#cc0000' : (correctA ? '#008000' : '#000000') %>;
          font-weight:<%= (chosenA || correctA) ? 'bold' : 'normal' %>;
        ">
          A) <%= q.opt_a %>
        </span>
      </div>

      <!-- B -->
      <div class="option">
        <% const chosenB = q.chosen_key === "B"; const correctB = q.correct_key === "B"; %>
        <span style="
          color:<%= chosenB && !correctB ? '#cc0000' : (correctB ? '#008000' : '#000000') %>;
          font-weight:<%= (chosenB || correctB) ? 'bold' : 'normal' %>;
        ">
          B) <%= q.opt_b %>
        </span>
      </div>

      <!-- C -->
      <div class="option">
        <% const chosenC = q.chosen_key === "C"; const correctC = q.correct_key === "C"; %>
        <span style="
          color:<%= chosenC && !correctC ? '#cc0000' : (correctC ? '#008000' : '#000000') %>;
          font-weight:<%= (chosenC || correctC) ? 'bold' : 'normal' %>;
        ">
          C) <%= q.opt_c %>
        </span>
      </div>

      <!-- D -->
      <div class="option">
        <% const chosenD = q.chosen_key === "D"; const correctD = q.correct_key === "D"; %>
        <span style="
          color:<%= chosenD && !correctD ? '#cc0000' : (correctD ? '#008000' : '#000000') %>;
          font-weight:<%= (chosenD || correctD) ? 'bold' : 'normal' %>;
        ">
          D) <%= q.opt_d %>
        </span>
      </div>

    </div>

    <!-- RISPOSTA DATA -->
    <div>
      <b>Risposta data:</b> <%= q.chosen_key %>
    </div>

    <!-- RISPOSTA CORRETTA -->
    <div>
      <b>Risposta corretta:</b> <%= q.correct_key %>
    </div>

  </div>
<% }) %>

<!-- FIRME -->
<div class="signature">
  <div>
    ___________________________<br>
    Firma addestrando
  </div>

  <div>
    ___________________________<br>
    Firma istruttore
  </div>
</div>

</body>
</html>
