{{! views/admin/utenti.hbs }}
<div class="page-header">
  <h1 class="page-title">👥 Personale EFV</h1>
  <div style="display:flex;gap:8px;">
    <a href="/admin/gradi" class="btn btn-outline">🎖️ Gestione Gradi</a>
    <button class="btn btn-primary" onclick="document.getElementById('modal-nuovo').style.display='flex'">+ Nuovo EFV</button>
  </div>
</div>

<div class="section-card mb-3">
  <form method="get" class="filter-form">
    <input type="text" name="q" value="{{filtri.q}}" placeholder="Nome, grado, email, matricola..." class="form-input">
    <select name="categoria" class="form-select">
      <option value="">Tutte le categorie</option>
      <option value="Piloti"            {{#if (eq filtri.categoria "Piloti")}}selected{{/if}}>Piloti</option>
      <option value="Operatori di volo" {{#if (eq filtri.categoria "Operatori di volo")}}selected{{/if}}>Operatori di volo</option>
      <option value="Tecnici di volo"   {{#if (eq filtri.categoria "Tecnici di volo")}}selected{{/if}}>Tecnici di volo</option>
    </select>
    <select name="ruolo" class="form-select">
      <option value="">Tutti i ruoli</option>
      <option value="efv"        {{#if (eq filtri.ruolo "efv")}}selected{{/if}}>E.F.V.</option>
      <option value="istruttore" {{#if (eq filtri.ruolo "istruttore")}}selected{{/if}}>Istruttore</option>
      <option value="admin"      {{#if (eq filtri.ruolo "admin")}}selected{{/if}}>Admin</option>
    </select>
    <button type="submit" class="btn btn-secondary">Filtra</button>
    <a href="/admin/utenti" class="btn btn-outline">Reset</a>
  </form>
</div>

<div class="section-card">
  <table class="admin-table">
    <thead>
      <tr><th>Personale</th><th>Grado / Spec.</th><th>Categoria</th><th>Ruolo</th><th>Sede</th><th>Stato</th><th>Azioni</th></tr>
    </thead>
    <tbody>
      {{#each utenti}}
      <tr class="{{#unless attivo}}row-inactive{{/unless}}">
        <td>
          <div class="user-cell">
            <div class="user-avatar-sm">{{#if cognome}}{{cognome.[0]}}{{else}}{{username.[0]}}{{/if}}</div>
            <div>
              <div class="fw-600">{{cognome}} {{nome}}</div>
              <div class="text-muted small">{{email}}</div>
              <div class="text-muted small" style="font-family:monospace;font-size:11px;">@{{username}}</div>
            </div>
          </div>
        </td>
        <td class="small">
          <span style="font-family:monospace;font-weight:600;">
            {{#if grado}}{{grado}}{{/if}}{{#if specializzazione}} {{specializzazione}}{{/if}}
            {{#unless grado}}{{#unless specializzazione}}<span class="text-muted">—</span>{{/unless}}{{/unless}}
          </span>
          {{#if matricola}}<div class="text-muted" style="font-size:11px;font-family:monospace;">{{matricola}}</div>{{/if}}
        </td>
        <td><span class="badge role-cat">{{#if categoria}}{{categoria}}{{else}}—{{/if}}</span></td>
        <td>
          <span class="badge role-{{ruolo}}">
            {{#if (eq ruolo "efv")}}E.F.V.{{else if (eq ruolo "istruttore")}}Istruttore{{else}}{{ruolo}}{{/if}}
          </span>
        </td>
        <td class="small text-muted">{{#if sede_assegnazione}}{{sede_assegnazione}}{{else}}—{{/if}}</td>
        <td>
          {{#if attivo}}<span class="badge badge-ok">Attivo</span>{{else}}<span class="badge badge-err">Inattivo</span>{{/if}}
          {{#if (eq auth_type "ldap")}}<span class="badge" style="background:#e8f0fe;color:#1a56db;margin-left:4px;">🔒 AD</span>{{/if}}
        </td>
        <td>
          <div class="action-btns">
            <button class="btn-icon" title="Modifica"
              onclick="openModifica({{id}},'{{username}}','{{nome}}','{{cognome}}','{{email}}','{{ruolo}}','{{categoria}}','{{grado}}','{{specializzazione}}','{{matricola}}','{{sede_assegnazione}}','{{qualifica}}','{{telefono}}','{{auth_type}}')">✏️</button>
            <a class="btn-icon" href="/personale/{{id}}" title="Scheda">📋</a>
            <form method="post" action="/admin/utenti/{{id}}/toggle" style="display:inline">
              <button class="btn-icon">{{#if attivo}}🔴{{else}}🟢{{/if}}</button>
            </form>
            <button class="btn-icon" onclick="openReset({{id}},'{{username}}')">🔑</button>
            <form method="post" action="/admin/utenti/{{id}}/elimina" style="display:inline"
                  onsubmit="return confirm('Eliminare {{username}}?')">
              <button class="btn-icon btn-danger">🗑️</button>
            </form>
          </div>
        </td>
      </tr>
      {{else}}
      <tr><td colspan="7" class="text-center text-muted">Nessun utente trovato</td></tr>
      {{/each}}
    </tbody>
  </table>
</div>

<!-- Modal Nuovo EFV -->
<div id="modal-nuovo" class="modal-overlay" style="display:none">
  <div class="modal-box" style="max-width:680px;">
    <div class="modal-header">
      <h3>➕ Nuovo Personale EFV</h3>
      <button onclick="document.getElementById('modal-nuovo').style.display='none'" class="modal-close">✕</button>
    </div>
    <form method="post" action="/admin/utenti/nuovo" accept-charset="UTF-8">
      <p class="text-muted small" style="margin:0 0 12px;">Username generato automaticamente come <strong>nome.cognome</strong>. La password temporanea apparirà nel messaggio di conferma.</p>
      <div class="form-grid">
        <div class="form-group"><label>Nome *</label><input type="text" name="nome" class="form-input" required></div>
        <div class="form-group"><label>Cognome *</label><input type="text" name="cognome" class="form-input" required></div>
        <div class="form-group"><label>Email istituzionale *</label><input type="email" name="email" class="form-input" required placeholder="nome.cognome@mit.gov.it"></div>
        <div class="form-group">
          <label>Ruolo *</label>
          <select name="ruolo" class="form-select" required>
            <option value="efv">E.F.V.</option>
            <option value="istruttore">Istruttore</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="form-group">
          <label>Categoria</label>
          <select name="categoria" class="form-select">
            <option value="">— Seleziona —</option>
            <option value="Piloti">Piloti</option>
            <option value="Operatori di volo">Operatori di volo</option>
            <option value="Tecnici di volo">Tecnici di volo</option>
          </select>
        </div>
        <div class="form-group">
          <label>Grado</label>
          <select name="grado" class="form-select">
            <option value="">— Seleziona —</option>
            {{#each gradi}}
            <option value="{{this.codice}}">{{this.codice}} — {{this.descrizione}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>Specializzazione</label>
          <input type="text" name="specializzazione" class="form-input" placeholder="Es. Np/Ov, PIL, 1° Cl.">
        </div>
        <div class="form-group">
          <label>Qualifica</label>
          <select name="qualifica" class="form-select">
            <option value="">— Seleziona —</option>
            <option value="Istruttore specialità">Istruttore specialità</option>
            <option value="Istruttore">Istruttore</option>
            <option value="Pronto Impiego">Pronto Impiego</option>
            <option value="TACCO">TACCO</option>
            <option value="In Formazione">In Formazione</option>
          </select>
        </div>
        <div class="form-group"><label>Matricola</label><input type="text" name="matricola" class="form-input"></div>
        <div class="form-group"><label>Sede assegnazione</label><input type="text" name="sede_assegnazione" class="form-input"></div>
        <div class="form-group"><label>Telefono</label><input type="text" name="telefono" class="form-input"></div>
        <div class="form-group"><label>Data nascita</label><input type="date" name="data_nascita" class="form-input"></div>
        <div class="form-group"><label>Luogo nascita</label><input type="text" name="luogo_nascita" class="form-input"></div>
        <div class="form-group">
          <label>Tipo autenticazione</label>
          <select name="auth_type" class="form-select">
            <option value="ldap">🔒 Dominio AD (guardiacostiera.local)</option>
            <option value="local">🔑 Password locale</option>
          </select>
          <small class="text-muted">Scegli "Dominio AD" per il personale di volo, "Password locale" solo per account amministrativi.</small>
        </div>
      </div>
      <div class="form-group"><label>Note</label><textarea name="note" class="form-input" rows="2"></textarea></div>
      <div class="modal-footer">
        <button type="button" onclick="document.getElementById('modal-nuovo').style.display='none'" class="btn btn-outline">Annulla</button>
        <button type="submit" class="btn btn-primary">Crea EFV</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Modifica -->
<div id="modal-modifica" class="modal-overlay" style="display:none">
  <div class="modal-box" style="max-width:680px;">
    <div class="modal-header">
      <h3>✏️ Modifica — <span id="mod-username"></span></h3>
      <button onclick="document.getElementById('modal-modifica').style.display='none'" class="modal-close">✕</button>
    </div>
    <form id="form-modifica" method="post" accept-charset="UTF-8">
      <div class="form-grid">
        <div class="form-group"><label>Nome</label><input type="text" name="nome" id="mod-nome" class="form-input"></div>
        <div class="form-group"><label>Cognome</label><input type="text" name="cognome" id="mod-cognome" class="form-input"></div>
        <div class="form-group"><label>Email</label><input type="email" name="email" id="mod-email" class="form-input"></div>
        <div class="form-group">
          <label>Ruolo</label>
          <select name="ruolo" id="mod-ruolo" class="form-select">
            <option value="efv">E.F.V.</option>
            <option value="istruttore">Istruttore</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="form-group">
          <label>Categoria</label>
          <select name="categoria" id="mod-categoria" class="form-select">
            <option value="">—</option>
            <option value="Piloti">Piloti</option>
            <option value="Operatori di volo">Operatori di volo</option>
            <option value="Tecnici di volo">Tecnici di volo</option>
          </select>
        </div>
        <div class="form-group">
          <label>Grado</label>
          <select name="grado" id="mod-grado" class="form-select">
            <option value="">—</option>
            {{#each gradi}}
            <option value="{{this.codice}}">{{this.codice}} — {{this.descrizione}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>Specializzazione</label>
          <input type="text" name="specializzazione" id="mod-specializzazione" class="form-input" placeholder="Es. Np/Ov, PIL, 1° Cl.">
        </div>
        <div class="form-group">
          <label>Qualifica</label>
          <select name="qualifica" id="mod-qualifica" class="form-select">
            <option value="">—</option>
            <option value="Istruttore specialità">Istruttore specialità</option>
            <option value="Istruttore">Istruttore</option>
            <option value="Pronto Impiego">Pronto Impiego</option>
            <option value="TACCO">TACCO</option>
            <option value="In Formazione">In Formazione</option>
          </select>
        </div>
        <div class="form-group"><label>Matricola</label><input type="text" name="matricola" id="mod-matricola" class="form-input"></div>
        <div class="form-group"><label>Sede assegnazione</label><input type="text" name="sede_assegnazione" id="mod-sede" class="form-input"></div>
        <div class="form-group"><label>Telefono</label><input type="text" name="telefono" id="mod-tel" class="form-input"></div>
        <div class="form-group">
          <label>Tipo autenticazione</label>
          <select name="auth_type" id="mod-auth-type" class="form-select">
            <option value="ldap">🔒 Dominio AD (guardiacostiera.local)</option>
            <option value="local">🔑 Password locale</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" onclick="document.getElementById('modal-modifica').style.display='none'" class="btn btn-outline">Annulla</button>
        <button type="submit" class="btn btn-primary">Salva</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Reset Password -->
<div id="modal-reset" class="modal-overlay" style="display:none">
  <div class="modal-box" style="max-width:400px">
    <div class="modal-header">
      <h3>🔑 Reset Password — <span id="reset-username"></span></h3>
      <button onclick="document.getElementById('modal-reset').style.display='none'" class="modal-close">✕</button>
    </div>
    <form id="form-reset" method="post">
      <div class="form-group">
        <label>Nuova Password (min 8)</label>
        <input type="text" name="nuova_password" class="form-input" required minlength="8">
      </div>
      <div class="modal-footer">
        <button type="button" onclick="document.getElementById('modal-reset').style.display='none'" class="btn btn-outline">Annulla</button>
        <button type="submit" class="btn btn-primary">Aggiorna</button>
      </div>
    </form>
  </div>
</div>

<script>
function openModifica(id,username,nome,cognome,email,ruolo,categoria,grado,specializzazione,matricola,sede,qualifica,tel,authType){
  document.getElementById('mod-username').textContent        = username;
  document.getElementById('mod-nome').value                  = nome             || '';
  document.getElementById('mod-cognome').value               = cognome          || '';
  document.getElementById('mod-email').value                 = email            || '';
  document.getElementById('mod-ruolo').value                 = ruolo            || 'efv';
  document.getElementById('mod-categoria').value             = categoria        || '';
  document.getElementById('mod-grado').value                 = grado            || '';
  document.getElementById('mod-specializzazione').value      = specializzazione || '';
  document.getElementById('mod-qualifica').value             = qualifica        || '';
  document.getElementById('mod-matricola').value             = matricola        || '';
  document.getElementById('mod-sede').value                  = sede             || '';
  document.getElementById('mod-tel').value                   = tel              || '';
  document.getElementById('mod-auth-type').value             = authType         || 'ldap';
  document.getElementById('form-modifica').action            = '/admin/utenti/' + id + '/modifica';
  document.getElementById('modal-modifica').style.display    = 'flex';
}
function openReset(id,username){
  document.getElementById('reset-username').textContent = username;
  document.getElementById('form-reset').action = '/admin/utenti/' + id + '/password';
  document.getElementById('modal-reset').style.display = 'flex';
}
document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', e => { if(e.target===m) m.style.display='none'; });
});
</script>
