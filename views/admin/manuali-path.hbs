<div class="card">
  <div class="card-header">
    <div class="card-title">📚 Percorso Manuali</div>
  </div>

  <div class="card-body">
    <form method="POST">
      <div style="margin-bottom:15px;">
        <label>Percorso cartella manuali</label>
        <input 
          type="text" 
          name="path" 
          value="{{path}}" 
          style="width:100%;padding:10px;border:1px solid #ccc;border-radius:6px;"
        >
      </div>

      <button class="btn btn-primary">💾 Salva</button>
    </form>

    <div style="margin-top:20px;color:#666;font-size:13px;">
      Esempi:<br>
      /mnt/manuali<br>
      \\server\manuali
    </div>
  </div>
</div>