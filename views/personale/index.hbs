{{! views/personale/index.hbs }}
<div class="section-head">
  <div class="section-title">👥 Personale Equipaggi di Volo</div>
  <a href="/personale/gestione/nuovo" class="btn btn-primary">➕ Aggiungi Personale</a>
</div>

<!-- Filtri -->
<div class="card" style="margin-bottom:20px;">
  <div class="card-body">
    <form action="/personale" method="GET" class="filter-form">
      <div class="filter-row">
        <div class="form-group">
          <label>Cerca</label>
          <input type="text" name="cerca" value="{{filtri.cerca}}" placeholder="Nome, cognome, matricola...">
        </div>
        <div class="form-group">
          <label>Categoria</label>
          <select name="categoria">
            <option value="">Tutte</option>
            <option value="pilota" {{#if (eq filtri.categoria "pilota")}}selected{{/if}}>Pilota</option>
            <option value="operatore" {{#if (eq filtri.categoria "operatore")}}selected{{/if}}>Operatore</option>
            <option value="tecnico" {{#if (eq filtri.categoria "tecnico")}}selected{{/if}}>Tecnico</option>
          </select>
        </div>
        <div class="form-group">
          <label>Stato</label>
          <select name="stato">
            <option value="">Tutti</option>
            <option value="attivo">Attivo</option>
            <option value="sospeso">Sospeso</option>
            <option value="in_quiescenza">In quiescenza</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary" style="align-self:flex-end;">🔍 Cerca</button>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body" style="padding:0;">
    {{#if personale}}
    <table class="table">
      <thead>
        <tr>
          <th>Matricola</th>
          <th>Cognome e Nome</th>
          <th>Grado</th>
          <th>Categoria</th>
          <th>Sede</th>
          <th>Stato</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each personale}}
        <tr>
          <td><span style="font-family:'DM Mono',monospace;font-size:12px;">{{this.matricola}}</span></td>
          <td><strong>{{this.cognome}}</strong> {{this.nome}}</td>
          <td>{{this.grado}}</td>
          <td><span class="tag tag-blue">{{this.categoria}}</span></td>
          <td>{{this.sede_assegnazione}}</td>
          <td>
            {{#if (eq this.stato "attivo")}}<span class="tag tag-green">attivo</span>{{/if}}
            {{#if (eq this.stato "sospeso")}}<span class="tag tag-red">sospeso</span>{{/if}}
            {{#if (eq this.stato "in_quiescenza")}}<span class="tag tag-gold">quiescenza</span>{{/if}}
          </td>
          <td><a href="/personale/{{this.id}}" class="btn btn-ghost btn-sm">📋 Scheda</a></td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <div style="text-align:center;padding:48px;color:var(--text-muted);">
      <div style="font-size:48px;">👥</div>
      <p>Nessun personale trovato.</p>
    </div>
    {{/if}}
  </div>
</div>
