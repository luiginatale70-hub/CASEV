<div class="page-header">
  <h1 class="page-title">Pubblicazioni in Vigore</h1>
  <p class="page-sub">Documenti ufficiali e normative operative</p>
</div>

{{#unless pubs.length}}
<div class="card text-center py-5">
  <h3 class="mt-3 text-muted">Nessuna pubblicazione disponibile</h3>
  <p class="text-muted">Inserire i file PDF nella cartella <code>Pubblicazioni/</code> del progetto.</p>
</div>
{{/unless}}

{{#if pubs.length}}
<div class="card">
  <div class="card-header d-flex align-items-center gap-3">
    <span>{{pubs.length}} documento/i disponibile/i</span>
    <input type="text" id="searchPub" class="form-control form-control-sm" style="width:220px;" placeholder="Cerca...">
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Documento</th>
            <th>Dimensione</th>
            <th>Data</th>
            <th style="width:180px;">Azioni</th>
          </tr>
        </thead>
        <tbody>
          {{#each pubs}}
          <tr class="pub-row">
            <td>
              <div style="font-weight:500;">{{titolo}}</div>
              <div style="font-size:11px;color:#888;">{{nome_file}}</div>
            </td>
            <td style="color:#888;font-size:13px;">{{size_kb}} KB</td>
            <td style="color:#888;font-size:13px;">{{formatDate data}}</td>
            <td>
              <a href="/pubblicazioni/view/{{nome_file}}" target="_blank" class="btn btn-sm btn-outline-primary me-1">Visualizza</a>
              <a href="/pubblicazioni/download/{{nome_file}}" class="btn btn-sm btn-primary">Scarica</a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>
{{/if}}

<script>
document.getElementById('searchPub')?.addEventListener('input', function() {
  var q = this.value.toLowerCase();
  document.querySelectorAll('.pub-row').forEach(function(row) {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
});
</script>