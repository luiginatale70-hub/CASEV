<!-- NAV-CASEV-v1 -->
<% const __examMode = (typeof examMode !== 'undefined' && examMode); %>

<% if (__examMode) { %>
<!-- ══════════════════════════════════════════════════
     EXAM MODE: topbar compatta con timer
══════════════════════════════════════════════════ -->
<nav class="navbar naaf-exam-nav">
  <div class="container-fluid px-3">
    <div class="d-flex align-items-center gap-3 w-100">

      <!-- Logo testo CASEV -->
      <div style="color:var(--gold);font-weight:800;font-size:1rem;letter-spacing:2px;white-space:nowrap;">CASEV</div>
      <div style="color:rgba(255,255,255,.4);font-size:.72rem;letter-spacing:1px;white-space:nowrap;display:none;" class="d-sm-block">ESAME IN CORSO</div>

      <!-- Timer -->
      <div class="ms-2">
        <%
          const __rem0 = (typeof examTimer !== 'undefined' && examTimer && examTimer.remaining_seconds != null)
            ? Math.max(0, Number(examTimer.remaining_seconds) || 0)
            : 0;
          const last5 = __rem0 <= 300;
        %>
        <span id="naafTimer" data-remaining="<%= __rem0 %>" data-exam-id="<%= typeof examId !== 'undefined' ? examId : '' %>">
          ⏱ <span id="naafTimerText">--:--</span>
        </span>
        <% if (last5) { %>
          <span class="badge bg-warning text-dark ms-2" style="font-weight:700;">⚠️ Ultimi 5 min</span>
        <% } %>
        <script>
          (function () {
            var wrap = document.getElementById('naafTimer');
            var out  = document.getElementById('naafTimerText');
            if (!wrap || !out) return;
            var remaining = parseInt(wrap.getAttribute('data-remaining'), 10);
            if (isNaN(remaining)) remaining = 0;
            var examId = wrap.getAttribute('data-exam-id');
            function fmt(s) {
              s = Math.max(0, s|0);
              return String(Math.floor(s/60)).padStart(2,'0') + ':' + String(s%60).padStart(2,'0');
            }
            function tick() {
              out.textContent = fmt(remaining);
              if (remaining <= 0) {
                if (examId) window.location.href = '/student/exams/' + encodeURIComponent(examId) + '/timeout';
                return;
              }
              remaining -= 1;
              setTimeout(tick, 1000);
            }
            tick();
          })();
        </script>
      </div>

      <!-- User email -->
      <div class="ms-auto d-none d-md-flex align-items-center gap-2">
        <% if (user) { %>
          <span style="color:rgba(255,255,255,.55);font-size:.78rem;font-family:'DM Mono',monospace;"><%= user.email %></span>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Navigator domande -->
  <% if (typeof qNav !== 'undefined' && qNav && qNav.length) { %>
    <div class="naaf-exam-index border-top">
      <div class="container-fluid py-2 px-3">
        <div class="naaf-index-scroll d-flex gap-1">
          <% qNav.forEach(q => {
               const isCurrent = (q.n === n);
               const cls = isCurrent ? 'btn-primary' : (q.answered ? 'btn-success' : 'btn-outline-secondary');
          %>
            <a class="btn <%= cls %> btn-sm"
               href="/student/exams/<%= examId %>/q/<%= q.n %>"
               title="<%= q.answered ? 'Risposta salvata' : 'Non risposta' %>">
              <%= q.n %>
            </a>
          <% }) %>
        </div>
      </div>
    </div>
  <% } %>
</nav>

<!-- Contenuto esame direttamente nel body -->

<% } else { %>
<!-- ══════════════════════════════════════════════════
     NORMAL MODE: sidebar CASEV + layout a due colonne
══════════════════════════════════════════════════ -->
<div class="casev-layout">

  <!-- Sidebar -->
  <aside class="casev-sidebar" id="casevSidebar">

    <div class="sidebar-header">
      <div class="sidebar-logo-area">
        <div class="sidebar-logo-icon" style="background:none; padding:0;">
  <img src="/public/img/Logo-naaf.png" 
       alt="CASEV" 
       style="width:42px; height:42px; object-fit:contain;">
</div>
        <div>
          <div class="sidebar-logo-title">CASEV</div>
          <div class="sidebar-logo-sub">Centro Addestramento<br>Equipaggi di Volo</div>
        </div>
      </div>
      <div class="sidebar-badge">ESAMI ON-LINE</div>
    </div>

    <nav class="sidebar-nav">
      <% if (!currentUser) { %>
        <div class="nav-section">
          <div class="nav-section-label">Accesso</div>
          <a href="/login"><span class="nav-icon">🔑</span> Login</a>
        </div>
      <% } else { %>
        <div class="nav-section">
          <div class="nav-section-label">Principale</div>
          <a href="/dashboard"><span class="nav-icon">🏠</span> Dashboard</a>
        </div>

        <% if (currentUser.role === 'student') { %>
        <div class="nav-section">
          <div class="nav-section-label">Area Allievo</div>
          <a href="/student"><span class="nav-icon">🎓</span> Area personale</a>
          <a href="/student/exams"><span class="nav-icon">📋</span> I miei esami</a>
        </div>
        <% } %>

        <% if (currentUser.role === 'instructor' || currentUser.role === 'admin') { %>
        <div class="nav-section">
          <div class="nav-section-label">Area Istruttore</div>
          <a href="/instructor"><span class="nav-icon">✈️</span> Dashboard</a>
          <a href="/instructor/exams"><span class="nav-icon">📋</span> Elenco Esami</a>
          <a href="/instructor/exams/assign"><span class="nav-icon">📝</span> Assegna Esame</a>
          <a href="/instructor/questions"><span class="nav-icon">📚</span> Questionari</a>
          <a href="/instructor/questions/import"><span class="nav-icon">📥</span> Importa Excel</a>
        </div>
        <% } %>

        <% if (currentUser.role === 'admin') { %>
        <div class="nav-section">
          <div class="nav-section-label">Amministrazione</div>
          <a href="/admin"><span class="nav-icon">🛡️</span> Dashboard Admin</a>
          <a href="/admin/students"><span class="nav-icon">👥</span> Allievi</a>
          <a href="/admin/classes"><span class="nav-icon">🏫</span> Classi</a>
          <a href="/admin/audit"><span class="nav-icon">📊</span> Audit Log</a>
          <a href="/admin/access"><span class="nav-icon">🔐</span> Log Accessi</a>
          <a href="/admin/exams"><span class="nav-icon">📌</span> Tutti gli Esami</a>
        </div>
        <% } %>

        <div class="nav-section">
          <div class="nav-section-label">Portale Principale</div>
          <a href="http://localhost:3000" target="_blank"><span class="nav-icon">🌐</span> Portale CASEV</a>
        </div>
      <% } %>
    </nav>

    <div class="sidebar-footer">
      <% if (currentUser) { %>
      <div class="user-card">
        <div class="user-avatar">
          <%= currentUser.email ? currentUser.email[0].toUpperCase() : '?' %>
        </div>
        <div style="flex:1;min-width:0;">
          <div class="user-name" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= currentUser.email %>"><%= currentUser.email %></div>
          <div class="user-role"><%= currentUser.role %></div>
        </div>
        <a href="/logout" class="logout-btn" title="Esci">⏻</a>
      </div>
      <% } else { %>
      <a href="/login" style="color:rgba(255,255,255,.5);font-size:.82rem;text-decoration:none;">🔑 Accedi</a>
      <% } %>
    </div>
  </aside>

  <!-- Main -->
  <div class="casev-main">

    <!-- Topbar -->
    <div class="casev-topbar">
      <div class="d-flex align-items-center gap-3">
        <button class="d-lg-none border-0 p-1"
                style="background:none;color:var(--text-muted);font-size:18px;cursor:pointer;line-height:1;"
                onclick="document.getElementById('casevSidebar').classList.toggle('open')">☰</button>
        <span class="topbar-title">C.A.S.E.V. — Guardia Costiera Pescara</span>
      </div>
      <% if (currentUser) { %>
      <span class="topbar-user d-none d-md-inline">
        <%= currentUser.email %> &middot; <span style="color:var(--gold);font-weight:600;"><%= currentUser.role %></span>
      </span>
      <% } %>
    </div>

    <!-- Flash messages -->
    <% if (flash && (flash.success.length || flash.error.length || flash.info.length)) { %>
    <div style="padding: 12px 28px 0;">
      <% if (flash.success && flash.success.length) { %>
        <div class="alert alert-success alert-dismissible fade show mb-2">✅ <%= flash.success[0] %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
      <% } %>
      <% if (flash.error && flash.error.length) { %>
        <div class="alert alert-danger alert-dismissible fade show mb-2">⚠️ <%= flash.error[0] %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
      <% } %>
      <% if (flash.info && flash.info.length) { %>
        <div class="alert alert-info alert-dismissible fade show mb-2">ℹ️ <%= flash.info[0] %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
      <% } %>
    </div>
    <% } %>

    <!-- Content wrapper aperto — verrà chiuso da foot.ejs -->
    <div class="casev-content">

<% } %>
