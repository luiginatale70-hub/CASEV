<%- include('../partials/head') %>
<%- include('../partials/nav') %>


  <div class="bg-white border rounded-3 shadow-sm p-4 mb-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <div>
        <h1 class="h5 mb-0"><%= bank.exam_type %></h1>
        <div class="text-muted small">Questionario ID <%= bank.id %> — anteprima fino a 500 domande</div>
      </div>
      <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" href="/instructor/questions">Elenco</a>
        <a class="btn btn-primary" href="/instructor/exams/assign">Assegna esame</a>
      </div>
    </div>
  </div>

  <div class="bg-white border rounded-3 shadow-sm p-4">
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>ID</th>
            <th>Argomento</th>
            <th>Domanda</th>
            <th>Corretta</th>
          </tr>
        </thead>
        <tbody>
          <% if (!questions.length) { %>
            <tr><td colspan="4" class="text-muted">Nessuna domanda.</td></tr>
          <% } %>
          <% questions.forEach(q => { %>
            <tr>
              <td><%= q.id %></td>
              <td class="text-muted"><%= q.topic || '-' %></td>
              <td style="min-width: 420px;"><%= q.question %></td>
              <td><span class="badge bg-success"><%= q.correct_key %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
