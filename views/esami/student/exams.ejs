<%- include('../partials/head') %>
<%- include('../partials/nav') %>


  <div class="bg-white border rounded-3 shadow-sm p-4">
    <h1 class="h5 mb-3">I miei esami</h1>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>ID</th>
            <th>Tipologia</th>
            <th>Stato</th>
            <th>Risultato</th>
            <th class="text-end">Azione</th>
          </tr>
        </thead>
        <tbody>
          <% if (!rows.length) { %>
            <tr><td colspan="5" class="text-muted">Nessun esame assegnato.</td></tr>
          <% } %>
          <% rows.forEach(e => { %>
            <tr>
              <td><%= e.id %></td>
              <td><%= e.exam_type %></td>
              <td><span class="badge <%= e.status==='SVOLTO'?'bg-success':'bg-secondary' %>"><%= e.status %></span></td>
              <td><%= e.score_percent!=null ? (Number(e.score_percent).toFixed(1)+'%') : '-' %></td>
              <td class="text-end">
                <% if (e.status==='ASSEGNATO') { %>
                  <a class="btn btn-sm btn-primary" href="/student/exams/<%= e.id %>/start">Inizia</a>
                <% } else { %>
                  <a class="btn btn-sm btn-outline-secondary" href="/student/exams/<%= e.id %>/result">Vedi esito</a>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a class="btn btn-link" href="/student">Torna indietro</a>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
