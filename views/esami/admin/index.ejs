          <h5 class="card-title">Gestione classi</h5>
          <p class="card-text">Crea e visualizza classi per comando e categoria.</p>
          <a class="btn btn-outline-primary" href="/admin/classes">Vai</a>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card h-100 border rounded-3 shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Gestione allievi</h5>
