<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container py-4" style="max-width: 900px;">
  <div class="bg-white border rounded-3 shadow-sm p-4">
    <h1 class="h5 mb-3">Nuova classe</h1>
    <form method="post" action="/admin/classes/new">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">Comando</label>
          <input class="form-control" name="command" required />
        </div>
        <div class="col-md-4">
          <label class="form-label">Categoria</label>
          <select class="form-select" name="category" required>
            <option>Piloti</option>
            <option>Operatori di volo</option>
            <option>Tecnici di volo</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Nome classe</label>
          <input class="form-control" name="name" required />
        </div>
      </div>
      <div class="mt-3">
        <button class="btn btn-primary">Crea</button>
        <a class="btn btn-link" href="/admin/classes">Annulla</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/foot') %>
