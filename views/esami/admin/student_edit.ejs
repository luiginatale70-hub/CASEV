<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container py-4" style="max-width: 900px;">
  <div class="bg-white border rounded-3 shadow-sm p-4">
    <h1 class="h5 mb-3">Modifica allievo</h1>
    <form method="post" action="/admin/students/<%= student.id %>/edit">
      <div class="row g-3">
        <div class="col-md-3">
          <label class="form-label">Grado</label>
          <input class="form-control" name="rank" value="<%= student.rank %>" required />
        </div>
        <div class="col-md-3">
          <label class="form-label">Nome</label>
          <input class="form-control" name="name" value="<%= student.name %>" required />
        </div>
        <div class="col-md-3">
          <label class="form-label">Cognome</label>
          <input class="form-control" name="surname" value="<%= student.surname %>" required />
        </div>
        <div class="col-md-3">
          <label class="form-label">Qualifica</label>
          <input class="form-control" name="qualification" value="<%= student.qualification %>" />
        </div>
        <div class="col-md-6">
          <label class="form-label">Email (login)</label>
          <input class="form-control" value="<%= student.email %>" disabled />
          <div class="form-text">L'email è login univoco (non modificabile da qui).</div>
        </div>
        <div class="col-md-6">
          <label class="form-label">Classe</label>
          <select class="form-select" name="class_id">
            <option value="">-- Nessuna --</option>
            <% classes.forEach(c => { %>
              <option value="<%= c.id %>" <%= (String(student.class_id||'')===String(c.id)) ? 'selected':'' %>>
                <%= c.command %> / <%= c.category %> / <%= c.name %>
              </option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="mt-3">
        <button class="btn btn-primary">Salva</button>
        <a class="btn btn-link" href="/admin/students">Annulla</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/foot') %>
