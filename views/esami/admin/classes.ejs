<%- include('../partials/head') %>
<%- include('../partials/nav') %>


  <div class="bg-white border rounded-3 shadow-sm p-4 mb-3">
    <div class="d-flex justify-content-between align-items-center">
      <h1 class="h5 mb-0">Gestione classi</h1>
      <a class="btn btn-primary" href="/admin/classes/new">+ Nuova classe</a>
    </div>
    <p class="text-muted small mt-2 mb-0">
      Gestione delle classi per comando e categoria. L’eliminazione di una classe non cancella gli allievi.
    </p>

    <form class="row g-2 mt-3" method="get" action="/admin/classes">
      <div class="col-md-9">
        <input class="form-control" name="q" placeholder="Cerca per nome / comando / categoria" value="<%= q || '' %>">
      </div>
      <div class="col-md-3 d-grid">
        <button class="btn btn-outline-primary">Cerca</button>
      </div>
    </form>
  </div>

  <div class="bg-white border rounded-3 shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <div class="text-muted small">
        <% if (typeof total !== 'undefined') { %>
          Totale: <b><%= total %></b>
        <% } %>
      </div>
    </div>

    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Nome classe</th>
            <th>Comando</th>
            <th>Categoria</th>
            <th class="text-end">Azioni</th>
          </tr>
        </thead>
        <tbody>
          <% if (!classes || classes.length === 0) { %>
            <tr>
              <td colspan="5" class="text-muted text-center py-3">Nessuna classe presente.</td>
            </tr>
          <% } %>

          <% (classes || []).forEach(c => { %>
            <tr>
              <td><%= c.id %></td>
              <td><%= c.name %></td>
              <td><%= c.command %></td>
              <td><span class="badge bg-secondary"><%= c.category %></span></td>
              <td class="text-end">
                <a class="btn btn-sm btn-outline-primary" href="/admin/classes/<%= c.id %>/edit">Modifica</a>
                <form method="post" action="/admin/classes/<%= c.id %>/delete" class="d-inline" onsubmit="return confirm('Eliminare questa classe? Gli allievi verranno sganciati dalla classe.')">
                  <button class="btn btn-sm btn-outline-danger">Elimina</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if ((pages || 1) > 1) { %>
      <div class="mt-3">
        <%- include('../partials/pagination', { baseUrl: '/admin/classes', page, pages, query: { q: q || '' } }) %>
      </div>
    <% } %>

    <div class="mt-3">
      <a class="btn btn-link" href="/admin">← Torna alla Dashboard</a>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
