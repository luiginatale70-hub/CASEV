<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="bg-white border rounded-3 shadow-sm p-4 mb-3">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <h1 class="h5 mb-0">Domande caricate</h1>
    <% if (user && user.role === 'admin') { %>
      <a class="btn btn-primary" href="/esami/instructor/questions/import">Importa Excel</a>
    <% } %>
  </div>
  <p class="text-muted small mb-0">Elenco delle tipologie importate. Clicca per vedere le domande (anteprima fino a 500 righe).</p>
</div>

<div class="bg-white border rounded-3 shadow-sm p-4">
  <div class="table-responsive">
    <table class="table table-sm align-middle mb-0">
      <thead>
        <tr>
          <th>ID</th>
          <th>Tipologia</th>
          <th>Domande</th>
          <th>Creata</th>
          <% if (user && user.role === 'admin') { %>
          <th class="text-end">Azioni</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (!banks.length) { %>
          <tr><td colspan="5" class="text-muted">Nessun questionario. Importa un Excel.</td></tr>
        <% } %>
        <% banks.forEach(b => { %>
          <tr>
            <td><%= b.id %></td>
            <td><a href="/esami/instructor/questions/<%= b.id %>"><%= b.exam_type %></a></td>
            <td><span class="badge bg-secondary"><%= b.qcount %></span></td>
            <td class="text-muted"><%= b.created_at %></td>
            <% if (user && user.role === 'admin') { %>
            <td class="text-end">
              <form class="d-inline" method="post" action="/esami/instructor/questions/<%= b.id %>/delete"
                    onsubmit="return confirm('Eliminare questo questionario e tutte le domande?')">
                <button class="btn btn-sm btn-outline-danger">Elimina</button>
              </form>
            </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="mt-3">
    <a class="btn btn-link" href="/esami/instructor">Torna indietro</a>
  </div>
</div>

<%- include('../partials/foot') %>
