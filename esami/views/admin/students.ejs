<%- include('../partials/head') %>
<%- include('../partials/nav') %>

  <div class="bg-white border rounded-3 shadow-sm p-4 mb-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h1 class="h5 mb-1">Partecipanti agli esami</h1>
        <p class="text-muted small mb-0">
          Gli allievi vengono aggiunti automaticamente dal 
          <a href="/personale" target="_blank">Portale EFV →</a>
        </p>
      </div>
    </div>

    <form class="row g-2 align-items-end" method="get" action="/esami/admin/students">
      <div class="col-md-4">
        <label class="form-label">Comando</label>
        <select class="form-select" name="command">
          <option value="">Tutti</option>
          <% commands.forEach(c => { %>
            <option value="<%= c %>" <%= (filters.command===c) ? 'selected':'' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Categoria</label>
        <select class="form-select" name="category">
          <option value="">Tutte</option>
          <option value="Piloti" <%= filters.category==='Piloti'?'selected':'' %>>Piloti</option>
          <option value="Operatori di volo" <%= filters.category==='Operatori di volo'?'selected':'' %>>Operatori di volo</option>
          <option value="Tecnici di volo" <%= filters.category==='Tecnici di volo'?'selected':'' %>>Tecnici di volo</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Ricerca</label>
        <input class="form-control" name="q" placeholder="Nome, cognome, email…" value="<%= filters.q || '' %>">
      </div>
      <div class="col-12">
        <button class="btn btn-outline-primary w-100">Filtra</button>
      </div>
    </form>
  </div>

  <div class="bg-white border rounded-3 shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <div class="text-muted small">
        <% if (typeof total !== 'undefined') { %>
          Totale: <b><%= total %></b>
        <% } %>
      </div>
    </div>

    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>Grado</th>
            <th>Nome</th>
            <th>Cognome</th>
            <th>Email</th>
            <th>Ruolo</th>
            <th>Classe</th>
            <th class="text-end">Azioni</th>
          </tr>
        </thead>
        <tbody>
          <% if (!rows.length) { %>
            <tr><td colspan="7" class="text-muted text-center py-4">
              Nessun partecipante. Aggiungili dal <a href="/personale">Portale EFV</a>.
            </td></tr>
          <% } %>
          <% rows.forEach(s => { %>
            <%
              const roleLabel = s.role_at_assignment === 'instructor' ? '🎓 Istruttore' : '👤 Allievo';
              const roleBadge = s.role_at_assignment === 'instructor' ? 'bg-info text-dark' : 'bg-secondary';
            %>
            <tr>
              <td><%= s.rank %></td>
              <td><%= s.name %></td>
              <td><%= s.surname %></td>
              <td><small><%= s.email %></small></td>
              <td><span class="badge <%= roleBadge %>"><%= roleLabel %></span></td>
              <td class="text-muted small"><%= s.class_name ? (s.command + ' / ' + s.class_name) : '-' %></td>
              <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" href="/esami/admin/students/<%= s.id %>/edit">Modifica</a>
                <form class="d-inline" method="post" action="/esami/admin/students/<%= s.id %>/reset-password" onsubmit="return confirm('Resettare password?')">
                  <button class="btn btn-sm btn-outline-warning">Reset pwd</button>
                </form>
                <form class="d-inline" method="post" action="/esami/admin/students/<%= s.id %>/delete" onsubmit="return confirm('Eliminare partecipante?')">
                  <button class="btn btn-sm btn-outline-danger">Elimina</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (pages > 1) { %>
      <div class="mt-3">
        <%- include('../partials/pagination', {
          baseUrl: '/esami/admin/students',
          page,
          pages,
          query: {
            command: filters.command || '',
            category: filters.category || '',
            q: filters.q || ''
          }
        }) %>
      </div>
    <% } %>

    <div class="mt-3">
      <a class="btn btn-link" href="/esami/admin">← Torna indietro</a>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
