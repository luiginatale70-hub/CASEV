<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<%
  const _filters =
    (typeof filters !== 'undefined' && filters) ? filters :
    ((typeof __filters !== 'undefined' && __filters) ? __filters : {});
  const _page  = (typeof page  !== 'undefined' && page)  ? page  : 1;
  const _pages = (typeof pages !== 'undefined' && pages) ? pages : 1;
%>

<div class="container py-4">
  <div class="bg-white border rounded-3 shadow-sm p-4 mb-3">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
      <div>
        <h1 class="h5 mb-1">Log accessi</h1>
        <p class="text-muted mb-0">Filtra, pagina ed esporta CSV.</p>
      </div>

      <a class="btn btn-outline-secondary btn-sm"
         href="/esami/admin/access.csv?<%= new URLSearchParams(_filters || {}).toString() %>">Export CSV</a>
    </div>

    <form class="row g-2 mt-3" method="get" action="/esami/admin/access">
      <div class="col-md-2">
        <select class="form-select form-select-sm" name="event">
          <option value="">Tutti eventi</option>
          <option value="login_success" <%= (_filters.event==='login_success')?'selected':'' %>>login_success</option>
          <option value="login_failed"  <%= (_filters.event==='login_failed')?'selected':'' %>>login_failed</option>
          <option value="logout"        <%= (_filters.event==='logout')?'selected':'' %>>logout</option>
        </select>
      </div>
      <div class="col-md-4">
        <input class="form-control form-control-sm" name="q" placeholder="Cerca (email/ip/UA/user_id)"
               value="<%= _filters.q || '' %>">
      </div>
      <div class="col-md-2">
        <input class="form-control form-control-sm" type="date" name="from" value="<%= _filters.from || '' %>">
      </div>
      <div class="col-md-2">
        <input class="form-control form-control-sm" type="date" name="to" value="<%= _filters.to || '' %>">
      </div>
      <div class="col-md-2 d-grid">
        <button class="btn btn-primary btn-sm">Filtra</button>
      </div>
    </form>
  </div>

  <div class="card border rounded-3 shadow-sm">
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Data</th>
            <th>Evento</th>
            <th>User</th>
            <th>Email</th>
            <th>IP</th>
            <th>User Agent</th>
          </tr>
        </thead>
        <tbody>
          <% (rows || []).forEach(r => { %>
            <tr>
              <td class="text-nowrap"><%= r.created_at %></td>
              <td><span class="badge text-bg-secondary"><%= r.event %></span></td>
              <td><%= r.user_id ?? '' %></td>
              <td><%= r.email ?? '' %></td>
              <td><%= r.ip ?? '' %></td>
              <td class="text-truncate" style="max-width: 420px;"><%= r.user_agent ?? '' %></td>
            </tr>
          <% }) %>

          <% if (!(rows || []).length) { %>
            <tr><td colspan="6" class="text-muted p-3">Nessun evento trovato.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (_pages && _pages > 1) { %>
    <nav class="mt-3">
      <ul class="pagination pagination-sm mb-0">
        <% for (let p=1; p<=_pages; p++) { %>
          <li class="page-item <%= (p===_page)?'active':'' %>">
            <a class="page-link"
               href="/esami/admin/access?<%= new URLSearchParams({ ...(_filters||{}), page: p }).toString() %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>

</div>

<%- include('../partials/foot') %>
