<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container py-4" style="max-width: 900px;">
  <div class="bg-white border rounded-3 shadow-sm p-4">
    <h1 class="h5 mb-3">Nuovo istruttore</h1>
    <form method="post" action="/esami/admin/instructors/new">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Nome</label>
          <input class="form-control" name="name" required />
        </div>
        <div class="col-md-6">
          <label class="form-label">Cognome</label>
          <input class="form-control" name="surname" required />
        </div>
        <div class="col-md-12">
          <label class="form-label">Email (login)</label>
          <input class="form-control" type="email" name="email" required />
        </div>
      </div>
      <div class="mt-3">
        <button class="btn btn-primary">Crea e invia password provvisoria</button>
        <a class="btn btn-link" href="/esami/admin">Annulla</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/foot') %>
