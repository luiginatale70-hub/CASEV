<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<%
  const _filters =
    (typeof filters !== 'undefined' && filters) ? filters :
    ((typeof __filters !== 'undefined' && __filters) ? __filters : {});
  const _page  = (typeof page  !== 'undefined' && page)  ? page  : 1;
  const _pages = (typeof pages !== 'undefined' && pages) ? pages : 1;
%>


  <div class="bg-white border rounded-3 shadow-sm p-4 mb-3">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
      <div>
        <h1 class="h5 mb-1">Storico audit</h1>
        <p class="text-muted mb-0">Filtra, pagina ed esporta CSV.</p>
      </div>

      <a class="btn btn-outline-secondary btn-sm"
         href="/esami/admin/audit.csv?<%= new URLSearchParams(_filters || {}).toString() %>">Export CSV</a>
    </div>

    <form class="row g-2 mt-3" method="get" action="/esami/admin/audit">
      <div class="col-md-2">
        <input class="form-control form-control-sm" name="action" placeholder="action"
               value="<%= _filters.action || '' %>">
      </div>
      <div class="col-md-2">
        <input class="form-control form-control-sm" name="actor" placeholder="actor_user_id"
               value="<%= _filters.actor || '' %>">
      </div>
      <div class="col-md-2">
        <input class="form-control form-control-sm" name="entity_type" placeholder="entity_type"
               value="<%= _filters.entity_type || '' %>">
      </div>
      <div class="col-md-2">
        <input class="form-control form-control-sm" name="entity_id" placeholder="entity_id"
               value="<%= _filters.entity_id || '' %>">
      </div>
      <div class="col-md-2">
        <input class="form-control form-control-sm" type="date" name="from" value="<%= _filters.from || '' %>">
      </div>
      <div class="col-md-2">
        <input class="form-control form-control-sm" type="date" name="to" value="<%= _filters.to || '' %>">
      </div>

      <div class="col-md-10">
        <input class="form-control form-control-sm mt-2" name="q" placeholder="Cerca (ip/user agent/details)"
               value="<%= _filters.q || '' %>">
      </div>
      <div class="col-md-2 d-grid">
        <button class="btn btn-primary btn-sm mt-2">Filtra</button>
      </div>
    </form>
  </div>

  <div class="card border rounded-3 shadow-sm">
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Data</th>
            <th>Azione</th>
            <th>Actor</th>
            <th>Ruolo</th>
            <th>Entity</th>
            <th>IP</th>
          </tr>
        </thead>
        <tbody>
          <% (rows || []).forEach(r => { %>
            <tr>
              <td class="text-nowrap"><%= r.created_at %></td>
              <td><code><%= r.action %></code></td>
              <td><%= r.actor_user_id ?? '' %></td>
              <td><%= r.actor_role ?? '' %></td>
              <td><%= (r.entity_type ?? '') + ':' + (r.entity_id ?? '') %></td>
              <td><%= r.ip ?? '' %></td>
            </tr>
          <% }) %>

          <% if (!(rows || []).length) { %>
            <tr><td colspan="6" class="text-muted p-3">Nessuna azione trovata.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (_pages && _pages > 1) { %>
    <nav class="mt-3">
      <ul class="pagination pagination-sm mb-0">
        <% for (let p=1; p<=_pages; p++) { %>
          <li class="page-item <%= (p===_page)?'active':'' %>">
            <a class="page-link"
               href="/esami/admin/audit?<%= new URLSearchParams({ ...(_filters||{}), page: p }).toString() %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>

</div>

<%- include('../partials/foot') %>
