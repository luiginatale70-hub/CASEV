<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container py-4">
  <div class="bg-white border rounded-3 shadow-sm p-4 mb-3">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
      <div>
        <h1 class="h5 mb-1">Statistiche esami</h1>
        <p class="text-muted mb-0">KPI + breakdown per tipologia (filtro per data assegnazione).</p>
      </div>
    </div>

    <form class="row g-2 mt-3" method="get" action="/esami/admin/analytics">
      <div class="col-md-3">
        <input class="form-control form-control-sm" type="date" name="from" value="<%= filters?.from || '' %>">
      </div>
      <div class="col-md-3">
        <input class="form-control form-control-sm" type="date" name="to" value="<%= filters?.to || '' %>">
      </div>
      <div class="col-md-2 d-grid">
        <button class="btn btn-primary btn-sm">Applica</button>
      </div>
    </form>
  </div>

  <div class="row g-3">
    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body">
      <div class="text-muted small">Assegnati</div><div class="fs-4 fw-semibold"><%= kpi.assigned || 0 %></div>
    </div></div></div>

    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body">
      <div class="text-muted small">Avviati</div><div class="fs-4 fw-semibold"><%= kpi.started || 0 %></div>
    </div></div></div>

    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body">
      <div class="text-muted small">Completati</div><div class="fs-4 fw-semibold"><%= kpi.completed || 0 %></div>
    </div></div></div>

    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body">
      <div class="text-muted small">Timeout</div><div class="fs-4 fw-semibold"><%= kpi.timed_out || 0 %></div>
    </div></div></div>
  </div>

  <div class="row g-3 mt-1">
    <div class="col-md-4"><div class="card shadow-sm"><div class="card-body">
      <div class="text-muted small">Media punteggio (solo SVOLTO)</div>
      <div class="fs-4 fw-semibold"><%= (kpi.avg_score!=null) ? (Number(kpi.avg_score).toFixed(1) + '%') : '-' %></div>
    </div></div></div>

    <div class="col-md-4"><div class="card shadow-sm"><div class="card-body">
      <div class="text-muted small">Passati (solo SVOLTO)</div>
      <div class="fs-4 fw-semibold"><%= kpi.passed || 0 %></div>
    </div></div></div>

    <div class="col-md-4"><div class="card shadow-sm"><div class="card-body">
      <div class="text-muted small">Durata media (solo SVOLTO)</div>
      <div class="fs-4 fw-semibold">
        <%
          const s = (kpi.avg_duration_sec!=null) ? Math.round(Number(kpi.avg_duration_sec)) : null;
          const mm = (s!=null) ? Math.floor(s/60) : null;
          const ss = (s!=null) ? (s%60) : null;
        %>
        <%= (s==null) ? '-' : `${mm}m ${ss}s` %>
      </div>
    </div></div></div>
  </div>

  <div class="card shadow-sm mt-3">
    <div class="card-body">
      <h2 class="h6 mb-3">Breakdown per tipologia</h2>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Tipologia</th>
              <th>Assegnati</th>
              <th>Completati</th>
              <th>Passati</th>
              <th>Timeout</th>
              <th>Media score</th>
            </tr>
          </thead>
          <tbody>
            <% byType.forEach(r => { %>
              <tr>
                <td><%= r.exam_type %></td>
                <td><%= r.assigned %></td>
                <td><%= r.completed %></td>
                <td><%= r.passed %></td>
                <td><%= r.timed_out %></td>
                <td><%= (r.avg_score!=null) ? Number(r.avg_score).toFixed(1)+'%' : '-' %></td>
              </tr>
            <% }) %>
            <% if (!byType.length) { %>
              <tr><td colspan="6" class="text-muted p-3">Nessun dato nel range.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<%- include('../partials/foot') %>
