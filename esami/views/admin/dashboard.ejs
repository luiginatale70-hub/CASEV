<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<%
  const _accessRows =
    (typeof accessRows !== 'undefined' && accessRows) ? accessRows :
    (typeof accessLogRows !== 'undefined' && accessLogRows) ? accessLogRows :
    (typeof accessLogs !== 'undefined' && accessLogs) ? accessLogs :
    (typeof access !== 'undefined' && access) ? access : [];

  const _auditRows =
    (typeof auditRows !== 'undefined' && auditRows) ? auditRows :
    (typeof auditLogRows !== 'undefined' && auditLogRows) ? auditLogRows :
    (typeof auditLogs !== 'undefined' && auditLogs) ? auditLogs :
    (typeof audit !== 'undefined' && audit) ? audit : [];

  const _stats = (typeof stats !== 'undefined' && stats) ? stats : {};
%>



  <!-- Page header -->
  <div class="naaf-pagehead d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
      <h1 class="naaf-page-title mb-1">Dashboard Amministratore</h1>
      <p class="mb-0" style="color:rgba(255,255,255,.6); font-size:.88rem;">
        Aggiornata: <%= new Date().toLocaleString('it-IT') %>
      </p>
    </div>
    <div style="font-size:2rem; opacity:.35;">🛡️</div>
  </div>

  <!-- Statistiche principali -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="naaf-stat-card">
        <div class="naaf-stat-icon" style="background:rgba(37,99,235,.10); font-size:1.2rem;">🏫</div>
        <div class="naaf-stat-value"><%= _stats.classesTotal ?? 0 %></div>
        <div class="naaf-stat-label">Classi</div>
        <a class="naaf-stat-link" href="/esami/admin/classes">Gestisci →</a>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="naaf-stat-card">
        <div class="naaf-stat-icon" style="background:rgba(16,185,129,.10); font-size:1.2rem;">👤</div>
        <div class="naaf-stat-value"><%= _stats.studentsTotal ?? 0 %></div>
        <div class="naaf-stat-label">Allievi</div>
        <a class="naaf-stat-link" href="/esami/admin/students">Gestisci →</a>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="naaf-stat-card">
        <div class="naaf-stat-icon" style="background:rgba(245,158,11,.10); font-size:1.2rem;">📋</div>
        <div class="naaf-stat-value"><%= _stats.assignmentsTotal ?? 0 %></div>
        <div class="naaf-stat-label">Esami assegnati</div>
        <a class="naaf-stat-link" href="/esami/admin/exams">Gestisci →</a>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="naaf-stat-card">
        <div class="naaf-stat-icon" style="background:rgba(239,68,68,.10); font-size:1.2rem;">⏱️</div>
        <div class="naaf-stat-value"><%= _stats.inProgressTotal ?? 0 %></div>
        <div class="naaf-stat-label">In corso</div>
        <span class="naaf-stat-link" style="cursor:default; color:rgba(26,38,64,.4);">Timer attivo</span>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Audit & Accessi -->
    <div class="col-lg-6">
      <div class="card naaf-card-accent">
        <div class="card-header d-flex align-items-center gap-2">
          <span>📊</span> Audit & Accessi
        </div>
        <div class="card-body">
          <p class="text-muted mb-3" style="font-size:.88rem;">
            Usa i pulsanti per consultare i log completi o esportarli in formato CSV.
          </p>
          <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-sm btn-outline-secondary" href="/esami/admin/access">Vedi accessi</a>
            <a class="btn btn-sm btn-outline-primary" href="/esami/admin/access.csv">⬇ CSV accessi</a>
            <a class="btn btn-sm btn-outline-secondary" href="/esami/admin/audit">Vedi audit</a>
            <a class="btn btn-sm btn-outline-primary" href="/esami/admin/audit.csv">⬇ CSV audit</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Stato esami -->
    <div class="col-lg-6">
      <div class="card naaf-card-accent">
        <div class="card-header d-flex align-items-center gap-2">
          <span>📈</span> Stato Esami
        </div>
        <div class="card-body">
          <div class="row g-2 mb-3">
            <div class="col-6">
              <div class="p-3 rounded-3 text-center" style="background:rgba(16,185,129,.07); border:1px solid rgba(16,185,129,.15);">
                <div style="font-size:1.8rem; font-weight:700; color:#059669;"><%= _stats.takenTotal ?? 0 %></div>
                <div style="font-size:.78rem; font-weight:600; text-transform:uppercase; letter-spacing:.6px; color:rgba(5,150,105,.7);">Completati</div>
              </div>
            </div>
            <div class="col-6">
              <div class="p-3 rounded-3 text-center" style="background:rgba(239,68,68,.07); border:1px solid rgba(239,68,68,.15);">
                <div style="font-size:1.8rem; font-weight:700; color:#dc2626;"><%= _stats.timedOutTotal ?? 0 %></div>
                <div style="font-size:.78rem; font-weight:600; text-transform:uppercase; letter-spacing:.6px; color:rgba(220,38,38,.7);">Timeout</div>
              </div>
            </div>
          </div>
          <a class="btn btn-sm btn-outline-secondary" href="/esami/admin/exams">Vai a gestione esami →</a>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="naaf-footer">Portale NAAF &copy; <%= new Date().getFullYear() %></div>

<%- include('../partials/foot') %>
