<%- include('../partials/head') %>
<%- include('../partials/nav') %>


  <div class="bg-white border rounded-3 shadow-sm p-4">
    <h1 class="h5 mb-2">Cambio password</h1>
    <p class="text-muted small mb-3">Al primo accesso devi impostare una password definitiva.</p>
    <form method="post" action="/change-password">
      <div class="mb-3">
        <label class="form-label">Nuova password</label>
        <input class="form-control" type="password" name="password" autocomplete="new-password" required />
      </div>
      <div class="mb-3">
        <label class="form-label">Conferma password</label>
        <input class="form-control" type="password" name="password2" autocomplete="new-password" required />
      </div>
      <button class="btn btn-primary w-100">Aggiorna</button>
    </form>
  </div>
</div>

<%- include('../partials/foot') %>
