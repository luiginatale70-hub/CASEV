<%- include('../partials/head') %>
<%- include('../partials/nav') %>


  <div class="bg-white border rounded-3 shadow-sm p-4">
    <h1 class="h5 mb-2">Registrazione (opzionale)</h1>
    <p class="text-muted small mb-3">Consigliato: registrazione gestita dall'amministratore. Questa pagina è disponibile se serve.</p>

    <form method="post" action="/register">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Ruolo</label>
          <select class="form-select" name="role" required>
            <option value="student">Allievo</option>
            <option value="instructor">Istruttore</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Email</label>
          <input class="form-control" type="email" name="email" autocomplete="username" required />
        </div>
        <div class="col-md-12">
          <label class="form-label">Password</label>
          <input class="form-control" type="password" name="password" autocomplete="new-password" required />
          <div class="form-text">Minimo 8 caratteri.</div>
        </div>
      </div>
      <div class="mt-3">
        <button class="btn btn-primary w-100">Crea account</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/foot') %>
