<%- include('partials/head') %>
<%- include('partials/nav') %>

<!-- Se non loggato mostra landing, altrimenti redirect viene gestito dal server -->
<div style="max-width:900px;">

  <div class="naaf-pagehead d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
      <h1 class="naaf-page-title mb-1">Portale Esami C.A.S.E.V.</h1>
      <p class="mb-0">Gestione test teorici — Piloti ed EFV Componente Ala Fissa</p>
    </div>
    <div style="font-size:2.5rem;opacity:.35;">✈️</div>
  </div>

  <% if (!currentUser) { %>
  <!-- Landing per utenti non loggati -->
  <div class="card mb-4">
    <div class="card-body p-4">
      <p class="mb-3" style="color:var(--text-muted);">
        Sistema di somministrazione esami con domande randomizzate, timer integrato e reportistica PDF.
      </p>
      <a class="btn btn-primary" href="/login">🔑 Accedi al portale</a>
    </div>
  </div>
  <% } %>

  <div class="row g-3">
    <div class="col-md-4">
      <div class="card h-100 naaf-card-accent">
        <div class="card-body">
          <div style="font-size:1.8rem;margin-bottom:.6rem;">🛡️</div>
          <h5 class="card-title fw-bold">Amministratore</h5>
          <p class="card-text" style="font-size:.88rem;color:var(--text-muted);">Gestione utenti, classi, questionari e reset password.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 naaf-card-accent">
        <div class="card-body">
          <div style="font-size:1.8rem;margin-bottom:.6rem;">✈️</div>
          <h5 class="card-title fw-bold">Istruttore</h5>
          <p class="card-text" style="font-size:.88rem;color:var(--text-muted);">Import domande, assegnazione esami e report PDF.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 naaf-card-accent">
        <div class="card-body">
          <div style="font-size:1.8rem;margin-bottom:.6rem;">🎓</div>
          <h5 class="card-title fw-bold">Allievo</h5>
          <p class="card-text" style="font-size:.88rem;color:var(--text-muted);">Svolgimento esami con timer, 1 domanda per pagina e report errori.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/foot') %>
