<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container py-4" style="max-width: 900px;">
  <div class="bg-white border rounded-3 shadow-sm p-4">
    <h1 class="h5 mb-3">Nuovo allievo</h1>
    <form method="post" action="/esami/admin/students/new">
      <div class="row g-3">
        <div class="col-md-3">
          <label class="form-label">Grado</label>
          <input class="form-control" name="rank" required />
        </div>
        <div class="col-md-3">
          <label class="form-label">Nome</label>
          <input class="form-control" name="name" required />
        </div>
        <div class="col-md-3">
          <label class="form-label">Cognome</label>
          <input class="form-control" name="surname" required />
        </div>
        <div class="col-md-3">
          <label class="form-label">Qualifica</label>
          <input class="form-control" name="qualification" />
        </div>
        <div class="col-md-6">
          <label class="form-label">Email (login)</label>
          <input class="form-control" type="email" name="email" required />
          <div class="form-text">L'email è il login univoco dell'allievo.</div>
        </div>
        <div class="col-md-6">
          <label class="form-label">Classe</label>
          <select class="form-select" name="class_id">
            <option value="">-- Nessuna --</option>
            <% classes.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.command %> / <%= c.category %> / <%= c.name %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="mt-3">
        <button class="btn btn-primary">Crea e invia password provvisoria</button>
        <a class="btn btn-link" href="/esami/admin/students">Annulla</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/foot') %>
