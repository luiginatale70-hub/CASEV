<%- include('../partials/head') %>
<%- include('../partials/nav', { examMode: true, examId, qNav, n, total }) %>

<div class="container py-4" style="max-width: 1100px;">
  <div class="bg-white border rounded-3 shadow-sm p-4">

    <% if (typeof qNav !== 'undefined' && qNav && qNav.length) { %>
      <div class="naaf-exam-index border-bottom mb-3">
        <div class="container-fluid py-2 px-3">
          <div class="naaf-index-scroll d-flex gap-1">
            <% qNav.forEach(q => { %>
              <a class="btn btn-sm 
                <%= q.n == n ? 'btn-primary naaf-current' : (q.answered ? 'btn-success' : 'btn-outline-secondary') %>"
                href="/esami/student/exams/<%= examId %>/q/<%= q.n %>">
                <%= q.n %>
              </a>
            <% }) %>
          </div>
        </div>
      </div>
    <% } %>

    <% const pct = Math.round((n / total) * 100); %>

    <div class="d-flex justify-content-between align-items-center mb-2">
      <h1 class="h6 mb-0">Esame <%= examId %></h1>

      <span class="text-muted small">
        Domanda <%= n %> / <%= total %> — <b><%= pct %>%</b>
      </span>
    </div>
        
    <% if (examTimer) { %>

      <div id="naaf-timer-box" class="alert alert-info py-2 small mb-3" style="display:none;">
        Tempo rimanente:
        <b id="naaf-timer-text"></b>
      </div>

      <div id="naaf-last5-box" class="alert alert-warning py-2 small mb-3" style="display:none;">
        ⚠️ Ultimi <b>5 minuti</b>: completa l’esame e verifica di aver risposto a tutte le domande.
      </div>

      <script>
        (function() {
          let remaining = <%= examTimer && examTimer.remainingSeconds ? examTimer.remainingSeconds : 0 %>;

          const timerBox = document.getElementById('naaf-timer-box');
          const timerText = document.getElementById('naaf-timer-text');
          const last5Box = document.getElementById('naaf-last5-box');

          function updateTimer() {
            if (remaining <= 0) {
              window.location.href = "/esami/student/exams/<%= examId %>/timeout";
              return;
            }

            const min = Math.floor(remaining / 60);
            const sec = remaining % 60;

            timerText.textContent = `${min} min ${sec.toString().padStart(2,'0')} sec`;

            if (remaining > 300) {
              timerBox.style.display = "block";
              last5Box.style.display = "none";
            }

            if (remaining <= 300) {
              timerBox.style.display = "block";
              last5Box.style.display = "block";
            }

            remaining--;
          }

          updateTimer();
          setInterval(updateTimer, 1000);
        })();
      </script>

    <% } %>

    <div class="progress mb-3" style="height: 10px; --naaf-pct:<%= pct %>%;">
      <div class="progress-bar progress-bar-striped progress-bar-animated naaf-progress"
           role="progressbar"
           aria-valuenow="<%= pct %>"
           aria-valuemin="0"
           aria-valuemax="100">
      </div>
    </div>

    <h2 class="h5 mb-3"><%= item.question %></h2>

    <form method="post" action="/esami/student/exams/<%= examId %>/q/<%= n %>/answer">
      <div class="list-group mb-3">
        <% ['A','B','C','D'].forEach(k => { %>
        <% if (k === 'D' && !item.opt_d) return; %>
        <label class="list-group-item d-flex gap-2">
            <input class="form-check-input flex-shrink-0" type="radio" name="choice" value="<%= k %>" <%= item.chosen_key===k ? 'checked':'' %>>
            <span><b><%= k %>)</b>
              <%= (k==='A'?item.opt_a:(k==='B'?item.opt_b:(k==='C'?item.opt_c:item.opt_d))) %>
            </span>
          </label>
        <% }) %>
      </div>

      
      <div class="naaf-exam-actions d-flex flex-wrap gap-2 align-items-center">
        <% if (n > 1) { %>
          <a class="btn btn-outline-secondary" href="/esami/student/exams/<%= examId %>/q/<%= n-1 %>">← Indietro</a>
        <% } else { %>
          <button class="btn btn-outline-secondary" type="button" disabled>← Indietro</button>
        <% } %>

        <% if (n < total) { %>
          <a class="btn btn-outline-secondary" href="/esami/student/exams/<%= examId %>/q/<%= n+1 %>">Avanti →</a>
        <% } else { %>
          <button class="btn btn-outline-secondary" type="button" disabled>Avanti →</button>
        <% } %>

        <button class="btn btn-primary btn-lg naaf-btn-save ms-auto" name="action" value="save" type="submit">
          Salva e avanti →
        </button>

        <% if (n === total) { %>
          <% if (unanswered === 0) { %>
            <button class="btn btn-success btn-lg ms-2"
                    formaction="/esami/student/exams/<%= examId %>/finish"
                    type="submit">
              Concludi
            </button>
          <% } else { %>
            <span class="ms-2 text-warning small">
              Mancano <b><%= unanswered %></b> npm e per concludere
            </span>
          <% } %>
        <% } %>
      </div>
    </form>

    <div class="mt-3 small text-muted">
      Nota: l'esame non può essere chiuso se mancano risposte.
    </div>
  </div>


<%- include('../partials/foot') %>