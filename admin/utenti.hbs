{{! views/admin/utenti.hbs }}
<div class="section-head">
  <div style="display:flex;align-items:center;gap:12px;">
    <a href="/admin" class="btn btn-ghost btn-sm">← Dashboard</a>
    <div class="section-title" style="margin-bottom:0;">⚙️ Gestione Utenti</div>
  </div>
  <button class="btn btn-primary" onclick="document.getElementById('modal-nuovo').style.display='flex'">➕ Nuovo Utente</button>
</div>

<div class="card">
  <div class="card-body" style="padding:0;">
    {{#if utenti}}
    <table class="table">
      <thead>
        <tr>
          <th>Username</th>
          <th>Cognome e Nome</th>
          <th>Email</th>
          <th>Ruolo</th>
          <th>Ultimo Accesso</th>
          <th>Stato</th>
          <th>Azioni</th>
        </tr>
      </thead>
      <tbody>
        {{#each utenti}}
        <tr class="{{#unless this.attivo}}row-disabled{{/unless}}">
          <td><span class="mono">{{this.username}}</span></td>
          <td><strong>{{this.cognome}}</strong> {{this.nome}}</td>
          <td style="font-size:12px;color:var(--text-muted);">{{this.email}}</td>
          <td>
            {{#if (eq this.ruolo 'admin')}}<span class="tag tag-red">admin</span>{{/if}}
            {{#if (eq this.ruolo 'gestore')}}<span class="tag tag-gold">gestore</span>{{/if}}
            {{#if (eq this.ruolo 'allievo')}}<span class="tag tag-blue">allievo</span>{{/if}}
          </td>
          <td style="font-size:12px;color:var(--text-muted);">{{formatDateTime this.ultimo_accesso}}</td>
          <td>
            {{#if this.attivo}}<span class="tag tag-green">attivo</span>{{else}}<span class="tag tag-red">disattivo</span>{{/if}}
          </td>
          <td>
            <div style="display:flex;gap:6px;">
              <!-- Toggle attivo -->
              <form action="/admin/utenti/{{this.id}}/toggle" method="POST" style="display:inline;">
                <input type="hidden" name="_method" value="POST">
                <button type="submit" class="btn btn-ghost btn-sm" title="{{#if this.attivo}}Disattiva{{else}}Attiva{{/if}}">
                  {{#if this.attivo}}🔒{{else}}🔓{{/if}}
                </button>
              </form>
              <!-- Reset password -->
              <button class="btn btn-ghost btn-sm" onclick="apriResetPwd({{this.id}}, '{{this.username}}')" title="Reset Password">🔑</button>
            </div>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <div style="text-align:center;padding:48px;color:var(--text-muted);">
      <div style="font-size:48px;">👤</div>
      <p>Nessun utente trovato.</p>
    </div>
    {{/if}}
  </div>
</div>

{{! ── MODAL NUOVO UTENTE ── }}
<div id="modal-nuovo" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-title">➕ Crea Nuovo Utente</div>
      <button onclick="document.getElementById('modal-nuovo').style.display='none'" class="modal-close">✕</button>
    </div>
    <form action="/admin/utenti" method="POST" class="modal-body">
      <div class="grid-2">
        <div class="form-group">
          <label>Cognome *</label>
          <input type="text" name="cognome" required>
        </div>
        <div class="form-group">
          <label>Nome *</label>
          <input type="text" name="nome" required>
        </div>
      </div>
      <div class="form-group">
        <label>Username *</label>
        <input type="text" name="username" required placeholder="es. m.rossi" style="font-family:'DM Mono',monospace;">
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="cognome.nome@guardiacostiera.it">
      </div>
      <div class="grid-2">
        <div class="form-group">
          <label>Password *</label>
          <input type="password" name="password" required placeholder="minimo 8 caratteri">
        </div>
        <div class="form-group">
          <label>Ruolo *</label>
          <select name="ruolo" required>
            <option value="allievo">Allievo</option>
            <option value="gestore">Gestore</option>
            <option value="admin">Amministratore</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" onclick="document.getElementById('modal-nuovo').style.display='none'" class="btn btn-ghost">Annulla</button>
        <button type="submit" class="btn btn-primary">💾 Crea Utente</button>
      </div>
    </form>
  </div>
</div>

{{! ── MODAL RESET PASSWORD ── }}
<div id="modal-pwd" class="modal-overlay" style="display:none;">
  <div class="modal-box" style="max-width:400px;">
    <div class="modal-header">
      <div class="modal-title">🔑 Reset Password</div>
      <button onclick="document.getElementById('modal-pwd').style.display='none'" class="modal-close">✕</button>
    </div>
    <form id="form-pwd" action="" method="POST" class="modal-body">
      <p id="pwd-info" style="font-size:13px;color:var(--text-muted);margin-bottom:16px;"></p>
      <div class="form-group">
        <label>Nuova Password *</label>
        <input type="password" name="nuova_password" required placeholder="minimo 8 caratteri">
      </div>
      <div class="modal-footer">
        <button type="button" onclick="document.getElementById('modal-pwd').style.display='none'" class="btn btn-ghost">Annulla</button>
        <button type="submit" class="btn btn-primary">💾 Aggiorna Password</button>
      </div>
    </form>
  </div>
</div>

<script>
function apriResetPwd(id, username) {
  document.getElementById('form-pwd').action = '/admin/utenti/' + id + '/password';
  document.getElementById('pwd-info').textContent = 'Reset password per: ' + username;
  document.getElementById('modal-pwd').style.display = 'flex';
}
// Chiudi modal cliccando overlay
document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', function(e) { if (e.target === el) el.style.display = 'none'; });
});
</script>
